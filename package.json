{
  "name": "astro-auto-adapter",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "description": "Let's you choose between Astro Adapters based off of the `ASTRO_ADAPTER_MODE` environment variable.",
  "access": "public",
  "main": "dist/index.cjs",
  "browser": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.js"
    },
    "./dist/*": "./dist/*",
    "./src/*": "./src/*",
    "./package.json": "./package.json",
    "./cli": {
      "default": "./dist/cli.mjs"
    }
  },
  "directories": {
    "dist": "./dist",
    "src": "./src"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "astro": "astro",
    "dev": "astro dev",
    "start": "astro dev",
    "preview": "astro preview",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:custom-adapters": "vitest run tests/custom-adapters",
    "pre-release": "pnpm test && pnpm build",
    "semantic-release": "semantic-release"
  },
  "engines": {
    "node": ">=22"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/git",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            "dist/**",
            "src/**"
          ]
        }
      ]
    ]
  },
  "changelog": {
    "repo": "astro-auto-adapter",
    "labels": {
      "breaking": ":boom: Breaking Change",
      "enhancement": ":rocket: Enhancement",
      "bug": ":bug: Bug Fix",
      "documentation": ":memo: Documentation",
      "internal": ":house: Internal",
      "revert": ":rewind: Revert"
    },
    "cacheDir": ".changelog"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/okikio/astro-auto-adapter.git"
  },
  "keywords": [
    "withastro",
    "astro-adapter",
    "astro-utility",
    "cloudflare",
    "node",
    "deno",
    "vercel",
    "edge",
    "serverless",
    "astro"
  ],
  "author": {
    "name": "Okiki Ojo",
    "email": "hey@okikio.dev",
    "url": "https://okikio.dev"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/okikio/astro-auto-adapter/issues"
  },
  "homepage": "https://github.com/okikio/astro-auto-adapter",
  "devDependencies": {
    "@astrojs/cloudflare": "^13.1.7",
    "@astrojs/netlify": "^7.0.6",
    "@astrojs/node": "^10.0.4",
    "@astrojs/vercel": "^10.0.4",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@deno/astro-adapter": "^0.3.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "astro": "^6.1.3",
    "astro-sst": "^3.1.4",
    "semantic-release": "^25.0.3",
    "tsdown": "0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "zx": "^8.8.5"
  },
  "peerDependencies": {
    "@astrojs/cloudflare": ">=12",
    "@astrojs/netlify": ">=6",
    "@astrojs/node": ">=9",
    "@astrojs/vercel": ">=8",
    "@deno/astro-adapter": ">=0",
    "astro": ">=4",
    "astro-sst": ">=3"
  },
  "peerDependenciesMeta": {
    "@astrojs/cloudflare": {
      "optional": true
    },
    "@astrojs/netlify": {
      "optional": true
    },
    "@astrojs/node": {
      "optional": true
    },
    "@astrojs/vercel": {
      "optional": true
    },
    "@deno/astro-adapter": {
      "optional": true
    },
    "astro-sst": {
      "optional": true
    }
  },
  "bin": {
    "astro-auto-adapter": "./dist/cli.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "picocolors": "^1.1.1"
  }
}
